PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/chatapp
JWT_SECRET=your-jwt-secret-here

# Room Configuration
ROOM_EXPIRATION_HOURS=2
ROOM_WARNING_MINUTES=5
ROOM_MAX_PARTICIPANTS=50

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_ANONYMOUS=30
RATE_LIMIT_ROOMS=60
RATE_LIMIT_MESSAGES=60
RATE_LIMIT_USER=100

# Cleanup
EXPIRED_ROOMS_RETENTION_DAYS=30
QUEUE_STALE_THRESHOLD_MINUTES=5

# Security
PREVENT_NAME_SPOOFING=true
STRICT_ROOM_PRIVACY=true
LOGGING_ENABLED=true
LOG_LEVEL=info

# Toxicity Checking (Hugging Face Inference API)
# Get your free API token at https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=           # Required: Your Hugging Face API token (format: hf_...)
TOXICITY_MODEL=unitary/toxic-bert # Hugging Face model ID (default: ToxicBERT)
TOXICITY_THRESHOLD=0.5           # Confidence threshold 0.1-0.9 (0.3=strict, 0.5=balanced, 0.7=relaxed)
TOXICITY_FAIL_MODE=open          # Behavior when API fails: "open" (allow msgs) or "closed" (block all)

# Toxicity Cache Settings
# Cache reduces API calls and improves response time
TOXICITY_CACHE_ENABLED=true      # Enable response caching (recommended for performance)
TOXICITY_CACHE_TTL=3600          # Cache TTL in seconds (1 hour, increase for higher traffic)
TOXICITY_CACHE_MAX_SIZE=1000     # Maximum cached entries (increase for active communities)

# Toxicity Category Filtering (comma-separated)
# Only block messages if detected category is in this list
# Available: toxic, severe_toxic, obscene, threat, insult, identity_hate
TOXICITY_CATEGORIES=toxic,severe_toxic,obscene,threat,insult,identity_hate

# Circuit Breaker Settings
# Protects against repeated API failures
TOXICITY_CIRCUIT_BREAKER_THRESHOLD=5    # Number of failures before opening circuit
TOXICITY_CIRCUIT_BREAKER_TIMEOUT=300000 # Time in ms before retry (5 minutes)

# Local Rate Limiting (client-side protection against Hugging Face free tier limits)
TOXICITY_RATE_LIMIT_WINDOW=60000     # Time window in ms (1 minute)
TOXICITY_RATE_LIMIT_MAX=30             # Max requests per window (matches HF free tier: 30/min)

# Error Rate Monitoring
TOXICITY_ERROR_RATE_THRESHOLD=0.1    # Alert when >10% of requests fail

# Toxicity Whitelist Settings
# Prevent false positives for phrases incorrectly flagged as toxic
# Method 1: Path to JSON file with allowed phrases
TOXICITY_WHITELIST_PATH=config/toxicityWhitelist.json
# Method 2: Inline JSON array of whitelisted phrases
# TOXICITY_WHITELIST='["this is killing me", "you'"'"'re killing it"]'

# Admin Settings
ADMIN_SECRET_KEY=change-this-in-production